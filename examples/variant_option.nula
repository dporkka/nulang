// User-declared variant types — an Option-like type with construction
// and pattern matching. Nulang has no prelude: programs declare the
// variants they need.
//
// Run with: nulang examples/variant_option.nula

type Option[T] = Some(T) | None

fn unwrap_or(o: Option[Int], default: Int) -> Int {
    match o {
        Some(x) => x,
        None => default
    }
}

let present = Some(41)
let absent = None
unwrap_or(present, 0) + unwrap_or(absent, 1)
