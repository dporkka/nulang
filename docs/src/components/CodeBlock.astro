---
interface Props {
  /** Displayed as "Source: filename" in the header bar */
  filename?: string;
  /** Language for syntax highlighting (default: "nulang") */
  language?: string;
  /** The code string to display */
  code: string;
  /** Show the copy button (default: true) */
  showCopy?: boolean;
}

const {
  filename,
  language = 'nulang',
  code,
  showCopy = true,
} = Astro.props;

// Generate a unique ID for the copy button target
const blockId = `code-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="code-block-wrapper">
  <div class="code-block-header">
    {filename ? (
      <span class="code-block-filename">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:4px;">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
          <polyline points="10 9 9 9 8 9"/>
        </svg>
        {filename}
      </span>
    ) : (
      <span></span>
    )}
    {showCopy && (
      <button
        class="copy-button"
        data-code-id={blockId}
        aria-label="Copy code to clipboard"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:4px;">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
        </svg>
        Copy
      </button>
    )}
  </div>
  <pre class={`language-${language}`} style="margin:0;border-radius:0;"><code id={blockId} class={`language-${language}`}>{code}</code></pre>
</div>

<script>
  // Attach copy behavior to all copy buttons on the page
  document.addEventListener('click', (e) => {
    const btn = (e.target as Element).closest('.copy-button') as HTMLButtonElement | null;
    if (!btn) return;

    const codeId = btn.dataset.codeId;
    const codeEl = document.getElementById(codeId!);
    if (!codeEl) return;

    const text = codeEl.textContent ?? '';
    navigator.clipboard.writeText(text).then(() => {
      const originalHTML = btn.innerHTML;
      btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle;margin-right:4px;"><polyline points="20 6 9 17 4 12"/></svg> Copied!';
      btn.classList.add('copied');
      setTimeout(() => {
        btn.innerHTML = originalHTML;
        btn.classList.remove('copied');
      }, 2000);
    }).catch(() => {
      // Fallback for older browsers
      const textarea = document.createElement('textarea');
      textarea.value = text;
      textarea.style.position = 'fixed';
      textarea.style.opacity = '0';
      document.body.appendChild(textarea);
      textarea.select();
      document.execCommand('copy');
      document.body.removeChild(textarea);
    });
  });
</script>

<style>
  .copy-button.copied {
    @apply bg-green-800 text-green-200;
  }
</style>
